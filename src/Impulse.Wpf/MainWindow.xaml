<Window x:Class="Impulse.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Impulse" Height="900" Width="1500"
        Background="{StaticResource BgDark}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="180"/>
            <RowDefinition Height="160"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource BgPanel}" Padding="12,8">
            <DockPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Vertical" HorizontalAlignment="Right">
                    <TextBlock x:Name="ContextText" Style="{StaticResource Label}"
                               Foreground="{StaticResource Accent}"
                               HorizontalAlignment="Right" Margin="0,0,0,2"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock Style="{StaticResource Label}" Text="PROMPT" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="PromptText" Style="{StaticResource Body}" Foreground="{StaticResource Accent}" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Style="{StaticResource Label}" Text="TURN"/>
                    <TextBlock Style="{StaticResource Heading}" Margin="6,0,18,0" x:Name="TurnText"/>
                    <TextBlock Style="{StaticResource Label}" Text="PHASE"/>
                    <TextBlock Style="{StaticResource Heading}" Margin="6,0,18,0" x:Name="PhaseText"/>
                    <TextBlock Style="{StaticResource Label}" Text="ACTIVE"/>
                    <Border x:Name="ActivePlayerSwatch" Width="12" Height="12" Margin="6,0,4,0" CornerRadius="2"/>
                    <TextBlock Style="{StaticResource Heading}" x:Name="ActivePlayerText" Margin="0,0,18,0"/>
                    <Button x:Name="SeeLogButton" Content="SEE LOG" Padding="8,2" Margin="0,0,6,0"
                            Background="{StaticResource BgPanel2}" Foreground="{StaticResource FgPrimary}"
                            BorderBrush="{StaticResource Accent}" BorderThickness="1"
                            Click="SeeLogButton_Click"/>
                    <Button x:Name="LoadStateButton" Content="LOAD STATE" Padding="8,2"
                            Background="{StaticResource BgPanel2}" Foreground="{StaticResource FgPrimary}"
                            BorderBrush="{StaticResource Accent}" BorderThickness="1"
                            Click="LoadStateButton_Click"/>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="180"/>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="280"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{StaticResource BgDark}" BorderBrush="{StaticResource BgPanel}" BorderThickness="0,0,1,0">
                <Canvas x:Name="MapCanvas" ClipToBounds="True"/>
            </Border>

            <Border Grid.Column="1" Background="{StaticResource BgPanel}" Padding="8" BorderBrush="{StaticResource BgPanel2}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource Label}" x:Name="ImpulseTrackLabel" Text="IMPULSE TRACK"/>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource Body}" Foreground="{StaticResource FgMuted}" FontSize="10"
                               x:Name="ImpulseTrackSubLabel"
                               Text="oldest → newest (FIFO)" Margin="0,2,0,8"/>
                    <StackPanel DockPanel.Dock="Bottom" x:Name="ImpulseActionPanel" Margin="0,8,0,0"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="ImpulsePanel"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="2" Background="{StaticResource BgPanel}" Padding="8" BorderBrush="{StaticResource BgPanel2}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Style="{StaticResource Label}" Text="PLAYERS"/>
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="PlayersPanel"/>
                    </ScrollViewer>
                </DockPanel>
            </Border>

            <Border Grid.Column="3" Background="{StaticResource BgPanel}" Padding="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Style="{StaticResource Label}" Text="CARD DETAIL"/>
                    <Grid Grid.Row="1" x:Name="DetailContainer" Margin="0,8,0,8"/>
                    <TextBlock Grid.Row="2" Style="{StaticResource Label}" Text="RECENT DRAWS" Margin="0,8,0,4"/>
                    <ScrollViewer Grid.Row="3" MaxHeight="220" VerticalScrollBarVisibility="Auto">
                        <StackPanel x:Name="RevealsPanel"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="{StaticResource BgPanel2}" Padding="12,8" BorderBrush="{StaticResource BgPanel}" BorderThickness="0,1,0,1">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource Label}" x:Name="HandLabel" Text="HAND"/>
                <ScrollViewer DockPanel.Dock="Top" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="HandPanel" Orientation="Horizontal" Margin="0,4,0,0"/>
                </ScrollViewer>
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource Label}" x:Name="MineralsLabel" Text="MINERALS" Margin="0,8,0,0"/>
                <ScrollViewer DockPanel.Dock="Top" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                    <StackPanel x:Name="MineralsPanel" Orientation="Horizontal" Margin="0,4,0,0"/>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <Border Grid.Row="3" Background="{StaticResource BgPanel}" Padding="12,8">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Style="{StaticResource Label}" Text="LOG"/>
                <ScrollViewer x:Name="LogScroll" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="LogText" Style="{StaticResource Body}" FontFamily="Cascadia Mono, Consolas"
                               Foreground="{StaticResource FgMuted}" FontSize="11" TextWrapping="Wrap"/>
                </ScrollViewer>
            </DockPanel>
        </Border>
    </Grid>
</Window>
